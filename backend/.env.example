# ─── ParkFlow AI — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in real values

# ── Database ────────────────────────────────────────────────────────────────────
# Local:    postgresql://postgres:yourpassword@localhost:5432/parkflow
# Railway:  Get from Railway PostgreSQL service dashboard
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/parkflow"

# ── App ─────────────────────────────────────────────────────────────────────────
PORT=3001

# ── Auth ─────────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-strong-random-secret"

# ── Frontend ─────────────────────────────────────────────────────────────────────
# URL of the frontend (used for CORS)
FRONTEND_URL="http://localhost:3000"
